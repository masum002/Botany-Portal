rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Secure Admin Identifier
    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email == "mahfujar003@gmail.com" &&
             request.auth.token.email_verified == true;
    }

    // Books Collection Rules
    match /books/{bookId} {
      allow read, list: if true; // Botany students reading textbooks is publicly acceptable
      allow create: if isAdmin() && isValidBook(request.resource.data);
      allow update: if isAdmin() && isValidBook(request.resource.data);
      allow delete: if isAdmin();
    }

    function isValidBook(data) {
      return data.keys().hasAll(['title', 'year', 'oneDriveLink']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 300 &&
             data.year is string && (data.year == '1st-year' || data.year == '2nd-year' || data.year == '3rd-year' || data.year == '4th-year') &&
             data.oneDriveLink is string && data.oneDriveLink.size() > 10 && data.oneDriveLink.size() <= 2048;
    }

    // Queries Collection Rules
    match /queries/{queryId} {
      allow read, list, delete: if isAdmin();
      allow create: if isValidQuery(request.resource.data);
    }

    function isValidQuery(data) {
      return data.keys().hasAll(['name', 'email', 'message']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 150 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 300 &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 2000;
    }
  }
}
